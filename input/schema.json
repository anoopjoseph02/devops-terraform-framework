{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Infrastructure specification",
  "description": "Validated input for AI DevOps Terraform generator",
  "type": "object",
  "required": ["resource_group", "location", "environment", "resources"],
  "additionalProperties": false,
  "properties": {
    "resource_group": {
      "type": "string",
      "minLength": 2,
      "maxLength": 90,
      "description": "Azure Resource Group name"
    },
    "location": {
      "type": "string",
      "enum": [
        "eastus", "eastus2", "westus", "westus2",
        "westeurope", "northeurope", "uksouth", "ukwest",
        "southeastasia", "australiaeast", "centralindia"
      ]
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "staging", "prod"]
    },
    "tags": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "storage_account",
              "aks_cluster",
              "virtual_network",
              "subnet",
              "key_vault",
              "container_registry",
              "postgresql",
              "redis_cache",
              "service_bus",
              "app_service_plan",
              "function_app"
            ]
          },
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,61}[a-z0-9]$",
            "description": "Lowercase alphanumeric with hyphens, 3-63 chars"
          },
          "replication_type": {
            "type": "string",
            "enum": ["LRS", "GRS", "ZRS", "GZRS", "RA-GRS", "RA-GZRS"]
          },
          "account_tier": {
            "type": "string",
            "enum": ["Standard", "Premium"]
          },
          "account_kind": {
            "type": "string",
            "enum": ["BlobStorage", "BlockBlobStorage", "FileStorage", "Storage", "StorageV2"]
          },
          "node_count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "min_node_count": {
            "type": "integer",
            "minimum": 1
          },
          "max_node_count": {
            "type": "integer",
            "maximum": 100
          },
          "vm_size": {
            "type": "string"
          },
          "enable_auto_scaling": {
            "type": "boolean"
          },
          "network_plugin": {
            "type": "string",
            "enum": ["azure", "kubenet", "none"]
          },
          "sku": {
            "type": "string"
          },
          "sku_name": {
            "type": "string"
          },
          "soft_delete_retention_days": {
            "type": "integer",
            "minimum": 7,
            "maximum": 90
          },
          "purge_protection_enabled": {
            "type": "boolean"
          },
          "address_space": {
            "type": "array",
            "items": { "type": "string" }
          },
          "address_prefixes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "min_tls_version": {
            "type": "string",
            "enum": ["TLS1_0", "TLS1_1", "TLS1_2"]
          },
          "allow_blob_public_access": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
