{
  "resource_group": "aj-rg",
  "location": "eastus",
  "aks": {
    "name": "aj-aks-cluster",
    "dns_prefix": "ajaks",
    "kubernetes_version": "1.28.0",
    "node_pool": {
      "name": "nodepool1",
      "node_count": 2,
      "vm_size": "Standard_DS2_v2",
      "os_disk_size_gb": 30
    },
    "identity": {
      "type": "SystemAssigned"
    },
    "network_profile": {
      "network_plugin": "azure",
      "load_balancer_sku": "standard"
    }
  }
}
